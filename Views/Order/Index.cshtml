@model IEnumerable<CafeManagementSystem.Models.Order>
@{
    ViewData["Title"] = "Orders";
    ViewData["ActivePage"] = "Order";
}

<div class="breadcrumb">
    <i class="fa-solid fa-receipt" style="font-size:0.7rem;"></i>
    <span>Orders</span>
</div>

<div class="page-header fade-in-up">
    <div class="page-header-left">
        <h1>Order Management</h1>
        <p>Track, manage, and update customer orders.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-plus"></i> New Order
        </a>
    </div>
</div>

<div class="card fade-in-up delay-1">
    <div class="card-header">
        <div>
            <div class="card-title">All Orders</div>
            <div class="card-subtitle">Recent activity</div>
        </div>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Table</th>
                    <th>Waiter</th>
                    <th>Items</th>
                    <th>Status</th>
                    <th>Time</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center;padding:32px;color:var(--text-muted);">
                            <i class="fa-solid fa-receipt" style="font-size:1.8rem;display:block;margin-bottom:8px;opacity:0.4;"></i>
                            No orders found. Click "New Order" to start serving!
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-600">#@item.Id</td>
                        <td>
                            <div class="d-flex align-center gap-2">
                                <span class="status-dot @(item.TableInfo?.Status.ToString().ToLower() ?? "free")"></span>
                                Table @(item.TableInfo?.TableNumber ?? "?")
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-center gap-2">
                                <div style="width:24px;height:24px;border-radius:50%;background:rgba(200,149,58,0.2);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;">
                                    @((item.Waiter?.FullName ?? "U").Substring(0, 1).ToUpper())
                                </div>
                                @(item.Waiter?.FullName ?? "Unknown")
                            </div>
                        </td>
                        <td>@item.OrderItems.Sum(oi => oi.Quantity) items</td>
                        <td>
                            @{
                                var badgeClass = item.Status switch
                                {
                                    CafeManagementSystem.Models.OrderStatus.Pending => "badge-warning",
                                    CafeManagementSystem.Models.OrderStatus.Preparing => "badge-primary",
                                    CafeManagementSystem.Models.OrderStatus.Ready => "badge-info",
                                    CafeManagementSystem.Models.OrderStatus.Served => "badge-success",
                                    CafeManagementSystem.Models.OrderStatus.Cancelled => "badge-danger",
                                    _ => "badge-muted"
                                };
                            }
                            <span class="badge @badgeClass">@item.Status</span>
                        </td>
                        <td class="text-muted text-sm">@item.CreatedAt.ToLocalTime().ToString("hh:mm tt")</td>
                        <td style="text-align:right;">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline btn-sm">
                                Manage
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

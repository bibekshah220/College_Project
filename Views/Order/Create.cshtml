@model CafeManagementSystem.Models.Order
@{
    ViewData["Title"] = "New Order";
    ViewData["ActivePage"] = "Order";
}

<div class="breadcrumb">
    <a asp-action="Index"><i class="fa-solid fa-receipt"></i> Orders</a>
    <span>/</span>
    <span>New Order</span>
</div>

<div class="page-header fade-in-up">
    <div class="page-header-left">
        <h1>Create New Order</h1>
        <p>Select a table to start an order.</p>
    </div>
</div>

<div class="grid-2 fade-in-up delay-1">
    <div class="card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="field-validation-error"></div>

            <div class="form-group">
                <label asp-for="TableInfoId" class="form-label">Select Table</label>
                <div class="input-group">
                    <span class="input-group-icon"><i class="fa-solid fa-chair"></i></span>
                    <select asp-for="TableInfoId" class="form-control" asp-items="ViewBag.TableInfoId">
                        <option value="">-- Choose a Free Table --</option>
                    </select>
                </div>
                <span asp-validation-for="TableInfoId" class="field-validation-error"></span>
                <div class="text-sm text-muted mt-2">Only tables currently marked as "Free" can have new orders started.</div>
            </div>

            <div class="auth-divider"></div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary">
                    Start Order <i class="fa-solid fa-arrow-right"></i>
                </button>
                <a asp-action="Index" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>

    <div class="card" style="background:var(--bg-card2);display:flex;align-items:center;justify-content:center;flex-direction:column;border-style:dashed;">
        <div style="font-size:3rem;margin-bottom:16px;opacity:0.5;">🍽️</div>
        <div class="text-muted fw-600">Start Order First</div>
        <p class="text-sm text-muted mt-2 text-center" style="max-width:250px;">Once you assign a table, you will be taken to the order screen where you can add menu items.</p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model CafeManagementSystem.Models.MenuItem
@{
    ViewData["Title"] = "Add Menu Item";
    ViewData["ActivePage"] = "Menu";
}

<div class="breadcrumb">
    <a asp-action="Index"><i class="fa-solid fa-utensils"></i> Menu Items</a>
    <span>/</span>
    <span>Add Item</span>
</div>

<div class="page-header fade-in-up">
    <div class="page-header-left">
        <h1>Add New Item</h1>
        <p>Create a new item to serve your customers.</p>
    </div>
</div>

<div class="grid-2 fade-in-up delay-1">
    <div class="card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="field-validation-error"></div>

            <div class="form-group">
                <label asp-for="Name" class="form-label">Item Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Caramel Macchiato" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="CategoryId" class="form-label">Category</label>
                <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price" class="form-label">Price (₹)</label>
                <div class="input-group">
                    <span class="input-group-icon">₹</span>
                    <input asp-for="Price" class="form-control" placeholder="0.00" type="number" step="0.01" />
                </div>
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Description (Optional)</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description of the item..."></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-check">
                    <input asp-for="IsAvailable" type="checkbox" checked />
                    <span class="form-check-label">Available for ordering</span>
                </label>
            </div>

            <div class="auth-divider"></div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-check"></i> Save Item
                </button>
                <a asp-action="Index" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
    
    <div class="card" style="background:var(--bg-card2);display:flex;align-items:center;justify-content:center;flex-direction:column;border-style:dashed;">
        <div style="font-size:3rem;margin-bottom:16px;opacity:0.5;">📸</div>
        <div class="text-muted fw-600">Image upload coming soon</div>
        <p class="text-sm text-muted mt-2 text-center" style="max-width:250px;">You can link images via URL for now, or just use the default emoji icon.</p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

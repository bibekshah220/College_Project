@model CafeManagementSystem.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    ViewData["AuthPage"] = true;
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-bg"></div>

    <div class="auth-grid fade-in-up">
        <!-- LEFT: Branding -->
        <div class="auth-left">
            <div class="auth-logo">
                <div class="auth-logo-icon">☕</div>
                <span class="auth-logo-name">Brew &amp; Manage</span>
            </div>

            <h1 class="auth-heading">
                Join our<br/>
                <span>Cafe Team</span>
            </h1>
            <p class="auth-desc">
                Create an account to start managing orders, inventory, and serving customers better.
            </p>

            <div class="auth-features">
                <div class="auth-feature">
                    <div class="auth-feature-icon">🤝</div>
                    Collaborate with the team in real-time
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon">🚀</div>
                    Fast and efficient order processing
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon">🔐</div>
                    Secure role-based access control
                </div>
            </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="auth-right">
            <h2 class="auth-form-title">Create Account</h2>
            <p class="auth-form-sub">Sign up to get access to the dashboard</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="badge badge-danger" style="display:block;padding:10px 14px;border-radius:8px;margin-bottom:16px;"></div>
            }

            <form asp-action="Register" method="post" id="registerForm">
                
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <div class="input-group">
                        <span class="input-group-icon"><i class="fa-regular fa-user"></i></span>
                        <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                    </div>
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-icon"><i class="fa-regular fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="staff@cafe.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-icon"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Confirm Password</label>
                    <div class="input-group">
                        <span class="input-group-icon"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>

                <button type="submit" class="auth-submit" id="submitBtn">
                    <i class="fa-solid fa-user-plus"></i>
                    Register
                </button>
                
                <div style="text-align:center;margin-top:16px;">
                    <a asp-action="Login" style="font-size:0.85rem;color:var(--text-secondary);text-decoration:none;">
                        Already have an account? <span style="color:var(--primary);font-weight:600;">Sign in</span>
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('registerForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creating...';
        btn.disabled = true;
    });
</script>
}

@{
    ViewData["Title"] = "Access Denied";
    ViewData["AuthPage"] = true;
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-bg"></div>
    
    <div style="text-align:center; max-width:500px; padding:48px; background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-xl); box-shadow:var(--shadow-card); position:relative; z-index:1;" class="fade-in-up">
        
        <div style="font-size:4rem; margin-bottom:16px;">
            <i class="fa-solid fa-shield-halved" style="color:var(--danger); text-shadow:0 0 30px rgba(224,92,92,0.3);"></i>
        </div>
        
        <h1 class="auth-heading" style="font-size:1.8rem; margin-bottom:8px;">Access Denied</h1>
        <p class="auth-desc" style="margin-bottom:32px;">
            You don't have the required permissions to access this page. Please contact your cafe administrator if you believe this is an error.
        </p>
        
        <a asp-action="Index" asp-controller="Home" class="auth-submit" style="display:inline-flex; width:auto; padding:12px 28px;">
            <i class="fa-solid fa-arrow-left"></i> Return to Dashboard
        </a>
    </div>
</div>

@model CafeManagementSystem.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    ViewData["AuthPage"] = true;
    Layout = "_Layout";
}

<div class="container mt-5" style="max-width: 500px; padding-top: 50px;">
    <div class="card shadow-sm border-0" style="background: var(--bg-card);">
        <div class="card-body p-5">
            <h2 class="mb-4 text-center" style="color: var(--text-primary); font-weight: 700;">Login</h2>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3" style="font-size: 0.85rem;"></div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label text-muted"></label>
                    <input asp-for="Email" class="form-control" style="background: var(--bg-card2); border-color: var(--border); color: var(--text-primary);" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 0.8rem;"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Password" class="form-label text-muted"></label>
                    <input asp-for="Password" class="form-control" style="background: var(--bg-card2); border-color: var(--border); color: var(--text-primary);" />
                    <span asp-validation-for="Password" class="text-danger" style="font-size: 0.8rem;"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" style="background-color: var(--bg-card2); border-color: var(--border);" />
                    <label asp-for="RememberMe" class="form-check-label text-muted"></label>
                </div>

                <div class="d-grid gap-3">
                    <button type="submit" class="btn btn-primary py-2" style="font-weight: 600;">Login</button>
                    <div class="text-center">
                        <a asp-action="Register" class="text-decoration-none" style="color: var(--primary); font-size: 0.9rem;">Don't have an account? Register</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

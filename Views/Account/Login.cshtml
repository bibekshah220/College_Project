@model CafeManagementSystem.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    ViewData["AuthPage"] = true;
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-bg"></div>

    <div class="auth-grid fade-in-up">
        <!-- LEFT: Branding -->
        <div class="auth-left">
            <div class="auth-logo">
                <div class="auth-logo-icon">☕</div>
                <span class="auth-logo-name">Brew &amp; Manage</span>
            </div>

            <h1 class="auth-heading">
                Welcome back to your<br/>
                <span>Cafe Dashboard</span>
            </h1>
            <p class="auth-desc">
                Manage orders, tables, inventory, and billing — all in one elegant platform built for modern cafes.
            </p>

            <div class="auth-features">
                <div class="auth-feature">
                    <div class="auth-feature-icon">🍽️</div>
                    Real-time kitchen order tracking
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon">📊</div>
                    Live sales and revenue analytics
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon">📦</div>
                    Inventory with low-stock alerts
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon">🧾</div>
                    One-click billing and receipts
                </div>
            </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="auth-right">
            <h2 class="auth-form-title">Sign in</h2>
            <p class="auth-form-sub">Enter your credentials to access the dashboard</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="badge badge-danger" style="display:block;padding:10px 14px;border-radius:8px;margin-bottom:16px;"></div>
            }

            <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">
                <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-icon"><i class="fa-regular fa-envelope"></i></span>
                        <input asp-for="Email"
                               class="form-control"
                               placeholder="admin@cafe.com"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:7px;">
                        <label class="form-label" style="margin:0;">Password</label>
                        <a href="#" style="font-size:0.75rem;color:var(--primary);">Forgot password?</a>
                    </div>
                    <div class="input-group" id="passwordGroup">
                        <span class="input-group-icon"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Password"
                               class="form-control"
                               placeholder="••••••••"
                               id="passwordInput"
                               autocomplete="current-password" />
                        <button type="button" class="input-group-icon" id="togglePass"
                                style="background:none;border:none;color:var(--text-muted);cursor:pointer;padding-right:14px;">
                            <i class="fa-regular fa-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input asp-for="RememberMe" type="checkbox" />
                        <span class="form-check-label">Keep me signed in for 30 days</span>
                    </label>
                </div>

                <button type="submit" class="auth-submit" id="submitBtn">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Sign In to Dashboard
                </button>
                
                <div style="text-align:center;margin-top:16px;">
                    <a asp-action="Register" style="font-size:0.85rem;color:var(--text-secondary);text-decoration:none;">
                        Don't have an account? <span style="color:var(--primary);font-weight:600;">Register</span>
                    </a>
                </div>

                <div class="auth-divider"></div>

                <p style="text-align:center;font-size:0.78rem;color:var(--text-muted);">
                    Default admin:
                    <code style="color:var(--primary);background:rgba(200,149,58,0.08);padding:2px 6px;border-radius:4px;">admin@cafe.com</code>
                    /
                    <code style="color:var(--primary);background:rgba(200,149,58,0.08);padding:2px 6px;border-radius:4px;">Admin@123</code>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Toggle password visibility
    document.getElementById('togglePass').addEventListener('click', function () {
        const input = document.getElementById('passwordInput');
        const icon  = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'fa-regular fa-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'fa-regular fa-eye';
        }
    });

    // Submit loading state
    document.getElementById('loginForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Signing in...';
        btn.disabled = true;
    });
</script>
}

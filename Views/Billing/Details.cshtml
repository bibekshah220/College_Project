@model CafeManagementSystem.Models.Bill
@{
    ViewData["Title"] = $"Receipt B-{Model.Id:D4}";
    ViewData["ActivePage"] = "Billing";
}

<div class="breadcrumb">
    <a asp-action="Index"><i class="fa-solid fa-file-invoice-dollar"></i> Billing</a>
    <span>/</span>
    <span>Receipt B-@Model.Id.ToString("D4")</span>
</div>

<div class="page-header fade-in-up">
    <div class="page-header-left">
        <h1>Receipt</h1>
        <p>Order #@Model.OrderId • Table @(Model.Order?.TableInfo?.TableNumber ?? "?")</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline btn-sm" onclick="window.print()">
            <i class="fa-solid fa-print"></i> Print
        </button>
    </div>
</div>

<div class="fade-in-up delay-1" style="max-width:500px;margin:0 auto;">
    <div class="card" style="padding:40px;position:relative;overflow:hidden;">
        
        <!-- Watermark -->
        @if(Model.PaymentStatus == CafeManagementSystem.Models.PaymentStatus.Paid)
        {
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-30deg);font-size:6rem;font-weight:900;color:rgba(76,175,130,0.05);pointer-events:none;white-space:nowrap;">
                PAID IN FULL
            </div>
        }
        else
        {
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-30deg);font-size:6rem;font-weight:900;color:rgba(224,92,92,0.05);pointer-events:none;white-space:nowrap;">
                UNPAID
            </div>
        }

        <!-- Header -->
        <div style="text-align:center;border-bottom:2px dashed var(--border);padding-bottom:24px;margin-bottom:24px;">
            <div style="font-size:2rem;margin-bottom:8px;">☕</div>
            <h2 style="margin:0;color:var(--text-primary);font-weight:800;">Brew & Manage</h2>
            <div style="color:var(--text-muted);font-size:0.85rem;margin-top:4px;">123 Coffee Lane, Espresso City</div>
            
            <div style="margin-top:24px;display:flex;justify-content:space-between;text-align:left;font-size:0.85rem;">
                <div>
                    <div class="text-muted">Bill No.</div>
                    <div class="fw-600">B-@Model.Id.ToString("D4")</div>
                </div>
                <div style="text-align:right;">
                    <div class="text-muted">Date</div>
                    <div class="fw-600">@Model.GeneratedAt.ToLocalTime().ToString("MMM dd, yyyy")</div>
                    <div class="fw-600">@Model.GeneratedAt.ToLocalTime().ToString("hh:mm tt")</div>
                </div>
            </div>
        </div>

        <!-- Items -->
        <table style="width:100%;margin-bottom:24px;border-collapse:collapse;">
            <thead>
                <tr style="border-bottom:1px solid var(--border);">
                    <th style="text-align:left;padding:8px 0;font-size:0.8rem;text-transform:uppercase;color:var(--text-muted);">Item</th>
                    <th style="text-align:center;padding:8px 0;font-size:0.8rem;text-transform:uppercase;color:var(--text-muted);">Qty</th>
                    <th style="text-align:right;padding:8px 0;font-size:0.8rem;text-transform:uppercase;color:var(--text-muted);">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model.Order!.OrderItems)
                {
                    <tr style="border-bottom:1px dashed rgba(255,255,255,0.05);">
                        <td style="padding:12px 0;">@item.MenuItem?.Name</td>
                        <td style="padding:12px 0;text-align:center;">x@item.Quantity</td>
                        <td style="padding:12px 0;text-align:right;">₹@((item.UnitPrice * item.Quantity).ToString("0.00"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Totals -->
        <div style="border-bottom:2px dashed var(--border);padding-bottom:24px;margin-bottom:24px;">
            <div style="display:flex;justify-content:space-between;margin-bottom:8px;color:var(--text-secondary);">
                <span>Subtotal</span>
                <span>₹@Model.SubTotal.ToString("0.00")</span>
            </div>
            <div style="display:flex;justify-content:space-between;margin-bottom:8px;color:var(--text-secondary);">
                <span>Tax (5%)</span>
                <span>₹@Model.Tax.ToString("0.00")</span>
            </div>
            @if(Model.Discount > 0)
            {
                <div style="display:flex;justify-content:space-between;margin-bottom:8px;color:var(--success);">
                    <span>Discount</span>
                    <span>-₹@Model.Discount.ToString("0.00")</span>
                </div>
            }
            <div style="display:flex;justify-content:space-between;margin-top:16px;font-size:1.4rem;font-weight:700;color:var(--primary);">
                <span>Total</span>
                <span>₹@Model.TotalAmount.ToString("0.00")</span>
            </div>
        </div>

        <!-- Footer -->
        <div style="text-align:center;">
            @if(Model.PaymentStatus == CafeManagementSystem.Models.PaymentStatus.Unpaid)
            {
                <form asp-action="MarkAsPaid" method="post" style="margin-bottom:16px;">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary btn-block">
                        <i class="fa-solid fa-indian-rupee-sign"></i> Mark as Paid
                    </button>
                </form>
            }
            <div style="font-size:0.8rem;color:var(--text-muted);">Thank you for visiting!</div>
            <div style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">Please come again.</div>
        </div>
    </div>
</div>

<style>
@@media print {
    body * {
        visibility: hidden;
    }
    .card, .card * {
        visibility: visible;
    }
    .card {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        box-shadow: none !important;
        border: none !important;
    }
    .btn, .breadcrumb, .page-header {
        display: none !important;
    }
}
</style>
